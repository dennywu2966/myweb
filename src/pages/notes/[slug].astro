---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';
import { formatDateShort } from '@/lib/utils';
import { BASE_PATH } from '@/lib/base';

export async function getStaticPaths() {
  const notes = await getCollection('notes');
  return notes.map((note) => ({
    params: { slug: note.slug },
    props: { note },
  }));
}

const { note } = Astro.props;
const { title, date, tags, link } = note.data;
---

<Base title={`${title || 'Note'} | Denny`} description={note.body.slice(0, 160)}>
  <article class="max-w-3xl mx-auto px-4 py-12">
    <header class="mb-8">
      <div class="text-sm text-[var(--color-text-muted)] mb-2">
        <time datetime={date.toISOString()}>{formatDateShort(date)}</time>
      </div>
      
      {title && (
        <h1 class="text-2xl font-bold mb-2">
          {link ? (
            <a href={link} target="_blank" rel="noopener noreferrer" class="hover:text-primary-600 dark:hover:text-primary-400 flex items-center gap-2">
              {title}
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
              </svg>
            </a>
          ) : (
            title
          )}
        </h1>
      )}
      
      {tags && tags.length > 0 && (
        <div class="mt-2 flex gap-2 text-sm text-[var(--color-text-muted)]">
          {tags.map((tag) => (
            <span>#{tag}</span>
          ))}
        </div>
      )}
    </header>
    
    <div class="prose-custom">
      <p class="whitespace-pre-wrap">{note.body}</p>
    </div>
    
    <nav class="mt-12 pt-8 border-t border-[var(--color-border)]">
      <div class="flex justify-between text-sm">
        <a href={`${BASE_PATH}/notes`} class="text-primary-600 dark:text-primary-400 hover:underline">
          ← 返回 Notes
        </a>
      </div>
    </nav>
  </article>
</Base>