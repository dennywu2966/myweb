---
import Base from '@/layouts/Base.astro';
import BlogCard from '@/components/BlogCard.astro';
import NoteCard from '@/components/NoteCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');

const pinnedPosts = allPosts
  .filter((post) => post.data.pinned)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recentPosts = allPosts
  .filter((post) => !post.data.pinned)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const featuredPosts = [...pinnedPosts, ...recentPosts].slice(0, 5);

const notes = (await getCollection('notes'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 4);
---

<Base title="Denny | Search, AI infrastructure, engineering systems, and notes.">
  <div class="max-w-3xl mx-auto px-4 pt-16 pb-20">
    <!-- Identity + intro — generous whitespace above -->
    <section class="mb-16">
      <h1 class="text-3xl font-medium tracking-tight text-[var(--color-text)] mb-5">
        Denny
      </h1>

      <div class="space-y-3.5 text-[var(--color-text-muted)] leading-relaxed max-w-xl">
        <p>
          在做搜索、AI 基础设施和复杂工程系统，也持续记录思考。
          现在主要关注 agent、memory、检索与向量系统，以及 AI-native 的工程方法。
        </p>
        <p>
          喜欢把复杂问题拆开、想透、写清楚。
          这里会放文章、notes、项目，以及一些还没有长成正式文章的想法。
        </p>
      </div>

      <!-- Simple nav links — not a button bar -->
      <div class="mt-6 flex gap-5 text-sm text-[var(--color-text-muted)]">
        <a href="/about" class="hover:text-[var(--color-accent)] transition-colors duration-200">关于</a>
        <a href="/blog" class="hover:text-[var(--color-accent)] transition-colors duration-200">文章</a>
        <a href="/notes" class="hover:text-[var(--color-accent)] transition-colors duration-200">Notes</a>
      </div>
    </section>

    <!-- Divider -->
    <hr class="border-t border-[var(--color-border)] mb-10" />

    <!-- Selected writing -->
    <section class="mb-10">
      <h2 class="text-xs font-medium uppercase tracking-widest text-[var(--color-text-muted)] mb-1 opacity-60">
        写作
      </h2>
      <div class="divide-y divide-[var(--color-border)]">
        {featuredPosts.map((post) => (
          <BlogCard post={post} />
        ))}
      </div>
      {allPosts.length > 5 && (
        <div class="mt-4 pt-4">
          <a
            href="/blog"
            class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors duration-200"
          >
            查看全部 {allPosts.length} 篇 →
          </a>
        </div>
      )}
    </section>

    <!-- Divider -->
    <hr class="border-t border-[var(--color-border)] mb-10" />

    <!-- Notes stream -->
    <section>
      <h2 class="text-xs font-medium uppercase tracking-widest text-[var(--color-text-muted)] mb-1 opacity-60">
        Notes
      </h2>
      <p class="text-xs text-[var(--color-text-muted)] mb-4 opacity-60">
        记录正在学习、判断、试验和还没长成正式文章的东西。
      </p>
      <div>
        {notes.map((note) => (
          <NoteCard note={note}>
            {note.body.length > 120 ? note.body.slice(0, 120) + '...' : note.body}
          </NoteCard>
        ))}
      </div>
    </section>
  </div>
</Base>
