---
import Base from '@/layouts/Base.astro';
import { getCollection } from 'astro:content';

const talks = (await getCollection('talks'))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<Base title="演讲 | Denny" description="技术分享与演讲记录">
  <div class="max-w-3xl mx-auto px-4 pt-12 pb-20">
    <header class="mb-10">
      <h1 class="text-3xl font-medium tracking-tight text-[var(--color-text)] mb-3">演讲</h1>
      <p class="text-[var(--color-text-muted)] text-sm">做过的一些技术分享与演讲。</p>
    </header>
    
    <div class="space-y-6">
      {talks.map((talk) => (
        <article class="group">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="font-semibold group-hover:text-[var(--color-accent)] transition-colors">
                {talk.data.url ? (
                  <a href={talk.data.url} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1">
                    {talk.data.title}
                    <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
                    </svg>
                  </a>
                ) : (
                  talk.data.title
                )}
              </h3>
              <p class="mt-1 text-sm text-[var(--color-text-muted)]">{talk.data.description}</p>
              <p class="mt-1 text-xs text-[var(--color-text-muted)]">
                {talk.data.event} · {talk.data.date.getFullYear()}
                {talk.data.location && ` · ${talk.data.location}`}
              </p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </div>
</Base>
