---
import { formatDate, readingTime } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';
import { BASE_PATH } from '@/lib/base';

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { title, description, pubDate, tags } = post.data;
---

<article class="group">
  <a href={`${BASE_PATH}/blog/${post.slug}`} class="block py-4">
    <div class="flex flex-col md:flex-row md:items-baseline md:justify-between gap-2">
      <h3 class="font-medium group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
        {title}
      </h3>
      <time class="text-sm text-[var(--color-text-muted)] shrink-0">
        {formatDate(pubDate)}
      </time>
    </div>
    <p class="mt-1 text-sm text-[var(--color-text-muted)] line-clamp-2">
      {description}
    </p>
    {tags && tags.length > 0 && (
      <div class="mt-2 flex gap-2 text-xs text-[var(--color-text-muted)]">
        {tags.map((tag) => (
          <span>#{tag}</span>
        ))}
        <span>·</span>
        <span>{readingTime(post.body)} 分钟</span>
      </div>
    )}
  </a>
</article>