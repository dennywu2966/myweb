  /* Slow vertical drift — creates parallax as layers move at different speeds */
  @keyframes drift-small {
    from { transform: translateY(0); }
    to { transform: translateY(-50%); }
  }

  @keyframes drift-medium {
    from { transform: translateY(0); }
    to { transform: translateY(-50%); }
  }

  @keyframes drift-large {
    from { transform: translateY(0); }
    to { transform: translateY(-50%); }
  }

  /* Gentle twinkle for the largest stars */
  @keyframes twinkle {
    0% { opacity: 1; }
    50% { opacity: 0.6; }
    100% { opacity: 1; }
  }

  /* Reduce motion for accessibility */
  @media (prefers-reduced-motion: reduce) {
    .stars--small,
    .stars--medium,
    .stars--large {
      animation: none;
    }
  }
</style>
