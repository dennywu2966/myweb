---
import { siteConfig } from '@/lib/config';
import { BASE_PATH } from '@/lib/base';
---

<header class="border-b border-[var(--color-border)] sticky top-0 bg-[var(--color-bg)]/80 backdrop-blur-sm z-50">
  <div class="max-w-4xl mx-auto px-4 h-16 flex items-center justify-between">
    <a href={BASE_PATH} class="font-semibold text-lg tracking-tight">
      {siteConfig.title}
    </a>
    
    <nav class="hidden md:flex items-center gap-6 text-sm">
      <a href={`${BASE_PATH}/blog`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">文章</a>
      <a href={`${BASE_PATH}/archive`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">归档</a>
      <a href={`${BASE_PATH}/projects`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">项目</a>
      <a href={`${BASE_PATH}/talks`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">演讲</a>
      <a href={`${BASE_PATH}/notes`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">Notes</a>
      <a href={`${BASE_PATH}/about`} class="hover:text-primary-600 dark:hover:text-primary-400 transition-colors">关于</a>
    </nav>
    
    <div class="flex items-center gap-3">
      <button
        id="theme-toggle"
        class="p-2 rounded-lg hover:bg-[var(--color-border)] transition-colors"
        aria-label="切换主题"
      >
        <svg class="w-5 h-5 hidden dark:block" fill="currentColor" viewBox="0 0 24 24">
          <path d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z"/>
        </svg>
        <svg class="w-5 h-5 block dark:hidden" fill="currentColor" viewBox="0 0 24 24">
          <path d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z"/>
        </svg>
      </button>
      
      <button
        id="mobile-menu-toggle"
        class="md:hidden p-2 rounded-lg hover:bg-[var(--color-border)] transition-colors"
        aria-label="菜单"
      >
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
        </svg>
      </button>
    </div>
  </div>
  
  <nav id="mobile-menu" class="hidden md:hidden border-t border-[var(--color-border)] px-4 py-4">
    <div class="flex flex-col gap-4 text-sm">
      <a href={`${BASE_PATH}/blog`} class="hover:text-primary-600 dark:hover:text-primary-400">文章</a>
      <a href={`${BASE_PATH}/archive`} class="hover:text-primary-600 dark:hover:text-primary-400">归档</a>
      <a href={`${BASE_PATH}/projects`} class="hover:text-primary-600 dark:hover:text-primary-400">项目</a>
      <a href={`${BASE_PATH}/talks`} class="hover:text-primary-600 dark:hover:text-primary-400">演讲</a>
      <a href={`${BASE_PATH}/notes`} class="hover:text-primary-600 dark:hover:text-primary-400">Notes</a>
      <a href={`${BASE_PATH}/about`} class="hover:text-primary-600 dark:hover:text-primary-400">关于</a>
    </div>
  </nav>
</header>

<script>
  const themeToggle = document.getElementById('theme-toggle');
  const mobileMenuToggle = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');
  
  themeToggle?.addEventListener('click', () => {
    const isDark = document.documentElement.classList.toggle('dark');
    localStorage.setItem('theme', isDark ? 'dark' : 'light');
  });
  
  mobileMenuToggle?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('hidden');
  });
</script>