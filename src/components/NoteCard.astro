---
import { formatDateShort } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const { title, date, tags, link } = note.data;
---

<article class="group py-4">
  <div class="text-xs text-[var(--color-text-muted)] mb-2">
    <time datetime={date.toISOString()}>{formatDateShort(date)}</time>
  </div>
  
  <div class="space-y-2">
    {title && (
      <h3 class="font-medium group-hover:text-primary-600 dark:group-hover:text-primary-400 transition-colors">
        {link ? (
          <a href={link} target="_blank" rel="noopener noreferrer" class="flex items-center gap-1">
            {title}
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/>
            </svg>
          </a>
        ) : (
          <a href={`/notes/${note.slug}`}>{title}</a>
        )}
      </h3>
    )}
    <div class="text-sm text-[var(--color-text-muted)] leading-relaxed">
      <slot />
    </div>
  </div>
  
  {tags && tags.length > 0 && (
    <div class="mt-2 flex gap-2 text-xs text-[var(--color-text-muted)]">
      {tags.map((tag) => (
        <span>#{tag}</span>
      ))}
    </div>
  )}
</article>
