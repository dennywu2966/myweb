---
import { formatDateShort } from '@/lib/utils';
import type { CollectionEntry } from 'astro:content';

interface Props {
  note: CollectionEntry<'notes'>;
}

const { note } = Astro.props;
const { title, date, tags, link } = note.data;
---

<article class="group py-4 flex gap-4">
  <!-- Date column — fixed width, muted -->
  <time
    class="text-xs text-[var(--color-text-muted)] shrink-0 pt-0.5 w-12 opacity-60"
    datetime={date.toISOString()}
  >
    {formatDateShort(date)}
  </time>

  <!-- Content -->
  <div class="flex-1 min-w-0">
    {title && (
      <h3 class="text-sm font-medium mb-1">
        {link ? (
          <a
            href={link}
            target="_blank"
            rel="noopener noreferrer"
            class="text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200 flex items-center gap-1"
          >
            {title}
            <svg class="w-3 h-3 opacity-50" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/>
            </svg>
          </a>
        ) : (
          <a
            href={`/notes/${note.slug}`}
            class="text-[var(--color-text)] group-hover:text-[var(--color-accent)] transition-colors duration-200"
          >
            {title}
          </a>
        )}
      </h3>
    )}

    <!-- Note body — slot for content passed in -->
    <div class="text-sm text-[var(--color-text-muted)] leading-relaxed">
      <slot />
    </div>

    <!-- Tags — minimal, monospace -->
    {tags && tags.length > 0 && (
      <div class="mt-2 flex flex-wrap gap-2 text-xs font-mono text-[var(--color-text-muted)] opacity-60">
        {tags.map((tag) => (
          <span>#{tag}</span>
        ))}
      </div>
    )}
  </div>
</article>
